# Cloudflare Pages _headers
# Format: a path, then indented "Header-Name: value" lines.
# Prefix a line with "! " to remove a header.
# Limits: 100 rules, 2,000 chars per line.
# Note: headers here do NOT apply to responses generated by Pages Functions.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Security headers for every page
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Long cache for static assets
/style.css
  Cache-Control: public, max-age=31536000, immutable

# Example: remove a header on a specific path
/no-server-header
  ! Server
